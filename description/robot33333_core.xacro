<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="robot_description" params="prefix camera_name=zedm camera_model=zedm">

    <!-- Properties -->
    <xacro:if value="${prefix != ''}">
      <xacro:property name="prefix_" value="${prefix}_"/>
    </xacro:if>
    <xacro:if value="${prefix == ''}">
      <xacro:property name="prefix_" value=""/>
    </xacro:if>

    <xacro:property name="wheel_radius" value="0.08" />
    <xacro:property name="base_footprint_z_offset" value="0.0295" />

    <!-- Materials/Colors -->
    <material name="yellow">
      <color rgba="1 1 0 1"/>
    </material>

    <material name="orange">
      <color rgba="1 0.3 0.1 1"/>
    </material>

    <material name="blue">
      <color rgba="0.2 0.2 1 1"/>
    </material>

    <material name="red">
      <color rgba="1 0 0 1"/>
    </material>
    
    <link
      name="${prefix_}base_link">
      <inertial>
        <origin
          xyz="5.30122902455545E-16 4.14241466277791E-16 0.0126948063217029"
          rpy="0 0 0" />
        <mass
          value="0.629688250105366" />
        <inertia
          ixx="0.0012994160656344"
          ixy="4.458494668736E-19"
          ixz="-4.06943730363067E-19"
          iyy="0.00233280155813295"
          iyz="1.19231384548009E-19"
          izz="0.00359571092028894" />
      </inertial>
      <visual>
        <origin
          xyz="0 0 0"
          rpy="0 0 0" />
        <geometry>
          <mesh
            filename="file://$(find arcs_cohort_description)/meshes/robot1_base_link.STL" />
        </geometry>
        <material
          name="">
          <color
            rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
        </material>
      </visual>
      <collision>
        <origin
          xyz="0 0 0"
          rpy="0 0 0" />
        <geometry>
          <mesh
            filename="file://$(find arcs_cohort_description)/meshes/robot1_base_link.STL" />
        </geometry>
      </collision>
    </link>
    <link
      name="${prefix_}front_left_wheel_link">
      <inertial>
        <origin
          xyz="-1.888E-07 3.5593E-07 0.0069273"
          rpy="0 0 0" />
        <mass
          value="0.13821" />
        <inertia
          ixx="0.0003215"
          ixy="4.0549E-10"
          ixz="-2.1303E-10"
          iyy="0.0003215"
          iyz="-1.0165E-10"
          izz="0.00063022" />
      </inertial>
      <visual>
        <origin
          xyz="0 0 0"
          rpy="0 0 0" />
        <geometry>
          <mesh
            filename="file://$(find arcs_cohort_description)/meshes/robot1_front_left_wheel_link.STL" />
        </geometry>
        <material
          name="">
          <color
            rgba="0.79216 0.81961 0.93333 1" />
        </material>
      </visual>
      <collision>
        <origin
          xyz="0 0 0"
          rpy="0 0 0" />
        <geometry>
          <mesh
            filename="file://$(find arcs_cohort_description)/meshes/robot1_front_left_wheel_link.STL" />
        </geometry>
      </collision>
    </link>
    <joint
      name="${prefix_}front_left_wheel_joint"
      type="continuous">
      <origin
        xyz="0.108 0.089 0.01825"
        rpy="-1.5708 0 0" />
      <parent
        link="${prefix_}base_link" />
      <child
        link="${prefix_}front_left_wheel_link" />
      <axis
        xyz="0 0 1" />
      <dynamics
        damping="0"
        friction="0" />
    </joint>
    <link
      name="${prefix_}front_right_wheel_link">
      <inertial>
        <origin
          xyz="-1.888E-07 3.5593E-07 0.0069273"
          rpy="0 0 0" />
        <mass
          value="0.13821" />
        <inertia
          ixx="0.0003215"
          ixy="4.0549E-10"
          ixz="-2.1303E-10"
          iyy="0.0003215"
          iyz="-1.0165E-10"
          izz="0.00063022" />
      </inertial>
      <visual>
        <origin
          xyz="0 0 0"
          rpy="0 0 0" />
        <geometry>
          <mesh
            filename="file://$(find arcs_cohort_description)/meshes/robot1_front_right_wheel_link.STL" />
        </geometry>
        <material
          name="">
          <color
            rgba="0.79216 0.81961 0.93333 1" />
        </material>
      </visual>
      <collision>
        <origin
          xyz="0 0 0"
          rpy="0 0 0" />
        <geometry>
          <mesh
            filename="file://$(find arcs_cohort_description)/meshes/robot1_front_right_wheel_link.STL" />
        </geometry>
      </collision>
    </link>
    <joint
      name="${prefix_}front_right_wheel_joint"
      type="continuous">
      <origin
        xyz="0.108 -0.089 0.01825"
        rpy="1.5708 0 0" />
      <parent
        link="${prefix_}base_link" />
      <child
        link="${prefix_}front_right_wheel_link" />
      <axis
        xyz="0 0 -1" />
      <dynamics
        damping="0"
        friction="0" />
    </joint>
    <link
      name="${prefix_}back_left_wheel_link">
      <inertial>
        <origin
          xyz="-1.888E-07 3.5593E-07 0.0069273"
          rpy="0 0 0" />
        <mass
          value="0.13821" />
        <inertia
          ixx="0.0003215"
          ixy="4.0549E-10"
          ixz="-2.1303E-10"
          iyy="0.0003215"
          iyz="-1.0165E-10"
          izz="0.00063022" />
      </inertial>
      <visual>
        <origin
          xyz="0 0 0"
          rpy="0 0 0" />
        <geometry>
          <mesh
            filename="file://$(find arcs_cohort_description)/meshes/robot1_back_left_wheel_link.STL" />
        </geometry>
        <material
          name="">
          <color
            rgba="0.79216 0.81961 0.93333 1" />
        </material>
      </visual>
      <collision>
        <origin
          xyz="0 0 0"
          rpy="0 0 0" />
        <geometry>
          <mesh
            filename="file://$(find arcs_cohort_description)/meshes/robot1_back_left_wheel_link.STL" />
        </geometry>
      </collision>
    </link>
    <joint
      name="${prefix_}back_left_wheel_joint"
      type="continuous">
      <origin
        xyz="-0.108 0.089 0.01825"
        rpy="-1.5708 0 0" />
      <parent
        link="${prefix_}base_link" />
      <child
        link="${prefix_}back_left_wheel_link" />
      <axis
        xyz="0 0 1" />
      <dynamics
        damping="0"
        friction="0" />
    </joint>
    <link
      name="${prefix_}back_right_wheel_link">
      <inertial>
        <origin
          xyz="-1.888E-07 3.5593E-07 0.0069273"
          rpy="0 0 0" />
        <mass
          value="0.13821" />
        <inertia
          ixx="0.0003215"
          ixy="4.0549E-10"
          ixz="-2.1303E-10"
          iyy="0.0003215"
          iyz="-1.0165E-10"
          izz="0.00063022" />
      </inertial>
      <visual>
        <origin
          xyz="0 0 0"
          rpy="0 0 0" />
        <geometry>
          <mesh
            filename="file://$(find arcs_cohort_description)/meshes/robot1_back_right_wheel_link.STL" />
        </geometry>
        <material
          name="">
          <color
            rgba="0.79216 0.81961 0.93333 1" />
        </material>
      </visual>
      <collision>
        <origin
          xyz="0 0 0"
          rpy="0 0 0" />
        <geometry>
          <mesh
            filename="file://$(find arcs_cohort_description)/meshes/robot1_back_right_wheel_link.STL" />
        </geometry>
      </collision>
    </link>
    <joint
      name="${prefix_}back_right_wheel_joint"
      type="continuous">
      <origin
        xyz="-0.108 -0.089 0.01825"
        rpy="1.5708 0 0" />
      <parent
        link="${prefix_}base_link" />
      <child
        link="${prefix_}back_right_wheel_link" />
      <axis
        xyz="0 0 -1" />
      <dynamics
        damping="0"
        friction="0" />
    </joint>
    <link
      name="${prefix_}${camera_name}_camera_mount_link">
      <inertial>
        <origin
          xyz="0 0 0"
          rpy="0 0 0" />
        <mass
          value="0" />
        <inertia
          ixx="0"
          ixy="0"
          ixz="0"
          iyy="0"
          iyz="0"
          izz="0" />
      </inertial>
      <visual>
        <origin
          xyz="0 0 0"
          rpy="0 0 0" />
        <geometry>
          <mesh
            filename="file://$(find arcs_cohort_description)/meshes/robot1_camera_mount_link.STL" />
        </geometry>
        <material
          name="">
          <color
            rgba="1 1 1 1" />
        </material>
      </visual>
      <collision>
        <origin
          xyz="0 0 0"
          rpy="0 0 0" />
        <geometry>
          <mesh
            filename="file://$(find arcs_cohort_description)/meshes/robot1_camera_mount_link.STL" />
        </geometry>
      </collision>
    </link>
    <joint
      name="${prefix_}camera_mount_joint"
      type="fixed">
      <origin
        xyz="0.1345 0.0036809 0.039145"
        rpy="0 0 0" />
      <parent
        link="${prefix_}base_link" />
      <child
        link="${prefix_}${camera_name}_camera_mount_link" />
      <axis
        xyz="0 0 0" />
    </joint>
  </xacro:macro>
</robot>